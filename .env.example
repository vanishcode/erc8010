# NEXT_PUBLIC_VALIDATOR_ADDRESS="0x..."
# NEXT_PUBLIC_INITIALIZER_ADDRESS="0x..."

# Sepolia:
# NEXT_PUBLIC_VALIDATOR_ADDRESS="0x..."
# NEXT_PUBLIC_INITIALIZER_ADDRESS="0x..."

# ── Foundry Deployment ────────────────────────────────────
# Private key for contract deployment (with 0x prefix)
# PRIVATE_KEY="0x..."

# ── Demo App: Preset Account ──────────────────────────────
# The demo uses this private key directly for all operations —
# message signing, EIP-7702 authorization signing, and sending
# delegation transactions. No wallet connection needed.
# TESTNET ONLY — never use a mainnet private key.
# NEXT_PUBLIC_DEMO_PRIVATE_KEY="0x..."
